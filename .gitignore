# =============================================================================
# HCC Drug Discovery Pipeline — .gitignore
# =============================================================================

# ── Data (never commit — download via scripts/data_download.py) ──────────────
data/raw/
data/processed/
*.h5ad
*.h5
*.loom
*.mtx
*.mtx.gz
*.tsv.gz
*.tar
*.tar.gz
*.gz

# ── Auto-generated path config (created by scripts/data_download.py) ─────────
paths.py

# ── Saved model weights (too large for git) ───────────────────────────────────
models/*.pt
models/*.pkl
models/*.pth
models/*.ckpt

# ── Results (regenerated by running the pipeline) ─────────────────────────────
# results/figures/
results/tables/
# results/reports/

# ── Jupyter notebook checkpoints & temporary files ───────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Python cache & build artifacts ────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Virtual environments & conda ─────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.conda/
*.conda

# ── IDE and editor files ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
Thumbs.db

# ── R artifacts ───────────────────────────────────────────────────────────────
.Rhistory
.RData
.Rproj.user/
*.Rproj

# ── Scanpy & matplotlib cache ─────────────────────────────────────────────────
figures/
# Scanpy auto-saves figures here by default — results/figures/ is used instead

# ── Log files ─────────────────────────────────────────────────────────────────
*.log
*.out
*.err
logs/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Secrets & credentials ─────────────────────────────────────────────────────
.env
.env.*
secrets.json
credentials.json
*_key.json
*.pem

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── What IS committed ─────────────────────────────────────────────────────────
# env/environment.yml       conda environment spec
# env/requirements.txt      pip fallback
# env/setup_env.sh          automated setup script
# env/r_packages.R          R package installer
# scripts/*.py              standalone analysis scripts
# scripts/utils/*.py        shared utility modules
# notebooks/*.ipynb         analysis notebooks (without outputs)
# docs/                     documentation
# README.md
# METHODS.md (if at root)
